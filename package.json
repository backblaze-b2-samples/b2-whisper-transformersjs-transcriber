{
  "name": "b2-whisper-transcriber",
  "version": "1.0.0",
  "description": "Client-side Speech-to-Text with Whisper and Backblaze B2",
  "scripts": {
    "install:backend": "cd backend && npm install",
    "start:backend": "cd backend && npm start",
    "dev:backend": "cd backend && npm run dev",
    "start:frontend": "cd frontend && python3 -m http.server 8080",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f"
  },
  "keywords": ["whisper", "openai-whisper", "speech-to-text", "transcription", "audio-transcription", "asr", "automatic-speech-recognition", "transformers-js", "webassembly", "backblaze", "b2", "s3", "cloud-storage", "javascript", "client-side-ai", "browser-ai"],
  "author": "Backblaze",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/backblaze-b2-samples/b2-whisper-transcriber"
  },
  "engines": {
    "node": ">=18"
  }
}
